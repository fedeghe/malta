{

    "testEnvironment": "node",
    "testMatch": [
        "**/tests/**/*.spec.js"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
        "src/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
        "node_modules",
        "tests"
    ],
    "coverageDirectory": "<rootDir>/coverage/",
    "coverageThreshold": {
        "global": {
            "branches": 20,
            "functions": 30,
            "lines": 50,
            "statements": 50
        }
    },
    "verbose": false
}
